{
  "name": "@ntee/ntee-db",
  "version": "0.0.1",
  "description": "Node.js binding for nteedb — a pure-Go embedded log-structured KV store with secondary indexes supported",
  "license": "Apache-2.0",
  "author": "nickooan <nickooan@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickooan/ntee-db.git",
    "directory": "nteedb-js"
  },
  "homepage": "http://github.com/nickooan/ntee-db/tree/main/nteedb-js#readme",
  "bugs": {
    "url": "https://github.com/nickooan/ntee-db/issues"
  },
  "keywords": [
    "database",
    "embedded",
    "key-value",
    "kv-store",
    "secondary-index",
    "log-structured",
    "prefix-scan",
    "storage",
    "persistence",
    "ffi",
    "koffi",
    "golang",
    "prebuilt",
    "json"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "prebuilds",
    "!prebuilds/**/*.h"
  ],
  "scripts": {
    "build:native": "bash capi/build.sh",
    "test": "node --test"
  },
  "dependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "better-sqlite3": "^12.11.1",
    "lmdb": "^3.5.6"
  }
}
