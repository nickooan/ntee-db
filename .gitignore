# Go test binaries, coverage, and profiling output
*.test
*.out
*.prof
*.pprof
coverage.txt

# Stray binary from building the c-shared command directly (e.g. `go build` in
# capi/). The real library is emitted into ntee-db-js/prebuilds by capi/build.sh,
# and those prebuilds are committed on purpose — do not ignore *.so / *.dylib.
/capi/capi

# Node (ntee-db-js/ also has its own scoped .gitignore)
node_modules/
*.tgz

# Editors / IDEs
.idea/
.vscode/

# macOS Finder metadata
.DS_Store

# Benchmark scratch stores — ntee-db-js/bench/*.mjs create these with paths
# relative to the cwd, so they can land at the repo root when a bench is run from
# here (inside ntee-db-js/ they are also covered by that package's .gitignore).
# `!ntee-db-js/` keeps the tracked package directory from being ignored.
ntee-*/
!ntee-db-js/
lmdb-*/
sqlite-*/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Logs
*.log

# Local environment files
.env
.env.local
.env.*.local

# Assistant tooling
.claude/
