# Go test binaries, coverage, and profiling output
*.test
*.out
*.prof
*.pprof
coverage.txt

# Stray binary from building the c-shared command directly (e.g. `go build` in
# nteedb-js/capi/). The real library is emitted into nteedb-js/prebuilds by
# nteedb-js/capi/build.sh, and those prebuilds are committed on purpose — do not
# ignore *.so / *.dylib.
/nteedb-js/capi/capi

# Node (nteedb-js/ also has its own scoped .gitignore)
node_modules/
*.tgz

# Editors / IDEs
.idea/
.vscode/

# macOS Finder metadata
.DS_Store

# Benchmark scratch stores — nteedb-js/bench/*.mjs create these with paths
# relative to the cwd, so they can land at the repo root when a bench is run from
# here (inside nteedb-js/ they are also covered by that package's .gitignore).
# nteedb-js/ and nteedb-core/ have no hyphen after "ntee", so `ntee-*/` does not
# match the tracked directories.
ntee-*/
lmdb-*/
sqlite-*/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Logs
*.log

# Local environment files
.env
.env.local
.env.*.local

# Assistant tooling
.claude/
